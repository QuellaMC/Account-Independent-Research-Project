---
import Hero from '../components/Hero';
import PolicyCards from '../components/PolicyCards';
import ClaimMechanics from '../components/ClaimMechanics';
import Calculator from '../components/Calculator';
import IncomeTiers from '../components/IncomeTiers';
import PolicyUncertainty from '../components/PolicyUncertainty';
import Age18Transition from '../components/Age18Transition';
import NationalImpact from '../components/NationalImpact';
import ThemeToggle from '../components/ThemeToggle';
import '../styles/global.css';

import YahooFinance from 'yahoo-finance2';
const yahooFinance = new YahooFinance();

// Fallbacks matching historical S&P 500 behavior
let historicalMeanReturn = 0.125;
let historicalVolatility = 0.169;
let dataRangeConfig = "1950-2024 (Fallback)";

try {
  // Use yahoo-finance2 to fetch REAL historical data for ^GSPC at build time!
  // Note: historical() is deprecated, so we use chart() and extract quotes.
  const query = '^GSPC';
  const queryOptions = { period1: new Date('1950-01-01'), period2: new Date(), interval: '1mo' as const };
  const chartResult = await yahooFinance.chart(query, queryOptions);
  const result = chartResult.quotes;
  
  if (result && result.length > 24) {
    const firstYear = new Date(result[0].date).getFullYear();
    const lastYear = new Date(result[result.length - 1].date).getFullYear();
    
    const monthlyReturns = [];
    for(let i = 1; i < result.length; i++) {
        monthlyReturns.push( (result[i].close - result[i-1].close) / result[i-1].close );
    }
    
    const meanMonthly = monthlyReturns.reduce((a,b)=>a+b, 0) / monthlyReturns.length;
    let varSum = 0;
    for(const r of monthlyReturns) varSum += Math.pow(r - meanMonthly, 2);
    const varMonthly = varSum / monthlyReturns.length;
    
    historicalMeanReturn = meanMonthly * 12; // Annualized arithmetic mean
    historicalVolatility = Math.sqrt(varMonthly) * Math.sqrt(12); // Annualized standard deviation
    dataRangeConfig = `${firstYear}—${lastYear}`;
    console.log(`[Astro Build] Fetched real market data: Mean = ${(historicalMeanReturn*100).toFixed(2)}%, Volatility = ${(historicalVolatility*100).toFixed(2)}%`);
  }
} catch (e) {
   console.error("[Astro Build] Using fallback parameters for SP500 due to Yahoo Finance error", e);
}

const title = "Trump Account (530A) Policy Dashbard";
const description = "Explore the Generational Wealth Multiplier Effect using realistic Yahoo Finance Monte Carlo data.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
  </head>
  <body>
    <!-- Top-level background container for ultra dark aesthetics -->
    <div style={{ background: 'var(--page-glow)', minHeight: '100vh', position: 'relative' }}>
      
      <ThemeToggle client:only="react" />
      
      <Hero client:load dataRangeConfig={dataRangeConfig} />
      
      <PolicyCards client:load />
      
      <ClaimMechanics client:load />

      <section className="container section-spacing" id="calculator">
        <div style={{ textAlign: 'center', marginBottom: '64px' }}>
          <h2 style={{ fontSize: 'clamp(32px, 4vw, 48px)', fontWeight: 700, margin: '0 0 16px', letterSpacing: '-0.02em' }}>
            Test the <span className="text-gradient">Policy Leverage</span>
          </h2>
          <p style={{ color: 'var(--text-muted)', fontSize: '18px', maxWidth: '600px', margin: '0 auto' }}>
            Interact with a completely un-opinionated Monte Carlo simulation using the raw volatility of the S&P 500 history.
          </p>
        </div>
        
        <Calculator 
          client:load 
          historicalMeanReturn={historicalMeanReturn} 
          historicalVolatility={historicalVolatility} 
          dataRangeConfig={dataRangeConfig} 
        />
      </section>

      <IncomeTiers client:load />
      
      <PolicyUncertainty client:load />
      
      <Age18Transition client:load />
      
      <NationalImpact client:load />

      <footer style={{ textAlign: 'center', padding: '60px 20px', color: 'var(--text-muted)', borderTop: '1px solid var(--border-light)' }}>
        <p style={{ fontSize: '14px', maxWidth: '600px', margin: '0 auto', lineHeight: 1.6 }}>
          Data sourced from ^GSPC Yahoo Finance. Policy metrics mapped against Federal Register Proposed Regulations (Section 530A OBBBA).
        </p>
      </footer>
    </div>
  </body>
</html>
